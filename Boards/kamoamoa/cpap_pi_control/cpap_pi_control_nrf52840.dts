/*
 * CPAP PI Sensor Control board — Raytac MDBT50Q-P1M module (nRF52840)
 *
 * SPDX-License-Identifier: Apache-2.0
 */

/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <nordic/nrf52840_partition.dtsi>
#include "cpap_pi_control_nrf52840-pinctrl.dtsi"

/ {
	model = "CPAP PI Sensor Control nRF52840";
	compatible = "kamoamoa,cpap-pi-control-nrf52840";

	chosen {
		zephyr,boot-mode = &boot_mode0;
	};

	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpio1 8 GPIO_ACTIVE_LOW>;
			label = "LED1";
		};

		led1: led_1 {
			gpios = <&gpio1 9 GPIO_ACTIVE_LOW>;
			label = "LED2";
		};
	};

	zephyr,user {
		/* TCA9548A I2C mux reset — active low */
		tca-reset-gpios = <&gpio1 0 GPIO_ACTIVE_LOW>;
		/* PPG sensor interrupt (shared, via 30-pin FPC) */
		ppg-int-gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
	};

	aliases {
		led0 = &led0;
		led1 = &led1;
		watchdog0 = &wdt0;
	};
};

/* High-voltage mode: VDDH = DVDD = 3.3 V, REG0 supplies VDD/GPIO.
 * L4 (REG0 DCDC inductor) is unpopulated — REG0 stays in LDO mode.
 * board.c programs UICR REGOUT0 = 3V3 on first boot after an erase.
 */
&reg0 {
	status = "okay";
};

&adc {
	status = "okay";
};

&uicr {
	gpio-as-nreset;
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
	gpio-line-names = "XL1", "XL2", "FF1/AIN0", "FF2/AIN1", "FF3/AIN2",
			  "VREF/AIN3", "", "CS1", "SDA", "NFC1", "NFC2", "PPG_INT",
			  "SCL", "SPI_SCK", "SPI_MOSI", "", "", "CS2", "RESET",
			  "CS3", "CS4", "SPI_MISO", "CS5", "", "CS6", "", "", "",
			  "", "", "", "";
};

&gpio1 {
	status = "okay";
	gpio-line-names = "TCA_RST", "", "", "", "", "", "", "",
			  "LED1", "LED2", "", "", "", "", "", "";
};

/* TCA9548A I2C mux @0x70 (A0=A1=A2=GND) — PPG1-3 on ch0-2, T/H on ch3 */
&i2c0 {
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
};

/* Off-board SPI devices via 30-pin FPC, six chip-selects */
&spi1 {
	status = "okay";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio0 7 GPIO_ACTIVE_LOW>,   /* CS1 */
		   <&gpio0 17 GPIO_ACTIVE_LOW>,  /* CS2 */
		   <&gpio0 19 GPIO_ACTIVE_LOW>,  /* CS3 */
		   <&gpio0 20 GPIO_ACTIVE_LOW>,  /* CS4 */
		   <&gpio0 22 GPIO_ACTIVE_LOW>,  /* CS5 */
		   <&gpio0 24 GPIO_ACTIVE_LOW>;  /* CS6 */
};

&gpregret1 {
	status = "okay";

	boot_mode0: boot_mode@0 {
		compatible = "zephyr,retention";
		status = "okay";
		reg = <0x0 0x1>;
	};
};
