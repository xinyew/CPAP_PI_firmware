            <script type="text/javascript">
        window.addEventListener("message", function(event) {
            if (event.data.type === 'hsFormCallback' && event.data.eventName === 'onFormReady') {
                console.log("onFormReady heard...");
                var formId = event.data.id;
                console.log(formId);
                
                // Find the iframe containing this form
                var iframe = document.querySelector('iframe[class*="hs-form-iframe"]');
                
                if (iframe && iframe.contentDocument) {
                    console.log(iframe.contentDocument);
                    
                    // Check if iframe's parent has dark-theme class
                    var parent = iframe.parentElement;
                    if (parent && parent.classList.contains('dark-theme')) {
                        // Add dark-theme class to iframe
                        iframe.classList.add('dark-theme');
                        
                        // Add dark-theme class to form inside iframe
                        var form = iframe.contentDocument.querySelector('form');
                        if (form) {
                            form.classList.add('dark-theme');
                        }
                        console.log("Dark theme classes added");
                    }
                    
                    // Create a link element for your CSS file
                    var link = document.createElement('link');
                    link.rel = 'stylesheet';
                    link.type = 'text/css';
                    link.href = '/themes/custom/tekscan/dist/css/hubspot-forms.css';
                    
                    // Inject into the iframe's head
                    iframe.contentDocument.head.appendChild(link);
                    console.log("CSS injected successfully");
                }
            }
        });
      </script>
    </body>
  </html>
